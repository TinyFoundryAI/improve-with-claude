{
  "manifest_version": 3,
  "name": "Improve with Claude",
  "version": "1.0.0",
  "description": "Select text, right-click, and let Claude improve it. The improved text is copied to your clipboard, ready to paste.",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "offscreen",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
